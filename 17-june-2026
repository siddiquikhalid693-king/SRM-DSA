//roman integer
class Solution {
    public int romanToInt(String s) {
        int ans = 0;

        for (int i = 0; i < s.length(); i++) {
            int cur = get(s.charAt(i));
            int next = (i + 1 < s.length()) ? get(s.charAt(i + 1)) : 0;

            ans += (cur < next) ? -cur : cur;
        }

        return ans;
    }

    int get(char c) {
        if (c == 'I') return 1;
        if (c == 'V') return 5;
        if (c == 'X') return 10;
        if (c == 'L') return 50;
        if (c == 'C') return 100;
        if (c == 'D') return 500;
        return 1000;
    }
}
