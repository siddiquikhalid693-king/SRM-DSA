//longest common prefix
class Solution {
    public String longestCommonPrefix(String[] strs) {
        String p = strs[0];

        for (int i = 1; i < strs.length; i++) {
            while (!strs[i].startsWith(p)) {
                p = p.substring(0, p.length() - 1);
                if (p.isEmpty()) return "";
            }
        }

        return p;
    }
}
